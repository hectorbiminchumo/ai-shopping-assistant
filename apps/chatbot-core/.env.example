# OpenAI — LLM for chat responses and query parsing (config/ai.config.ts)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Voyage AI — text embeddings for semantic search (config/ai.config.ts)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
# Image embeddings for image-based search (Feature 2). Required — no code
# default. voyage-multimodal-3.5 @512d via REST (output_dimension not in the SDK).
VOYAGE_MULTIMODAL_MODEL=voyage-multimodal-3.5
VOYAGE_API_BASE_URL=https://api.voyageai.com/v1

# Supabase — pgvector (product_embeddings, chat_logs) + Auth (config/supabase.config.ts)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Medusa backend, used by the ingestion pipeline to read products
MEDUSA_BACKEND_URL=http://localhost:9000
